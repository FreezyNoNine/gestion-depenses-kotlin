<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/button_add_expense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/add_expense"
        android:onClick="onAddExpenseClick" />

    <Button
        android:id="@+id/button_view_expenses"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/view_expenses"
        android:onClick="onViewExpensesClick" />

    <Button
        android:id="@+id/button_view_statistics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/view_statistics"
        android:onClick="onViewStatisticsClick" />

    <Button
        android:id="@+id/button_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings"
        android:onClick="onSettingsClick" />

</LinearLayout>
